Set-PSReadLineOption -EditMode vi
Set-PSReadLineOption -ViModeIndicator Cursor
Set-PSReadLineKeyHandler -Chord Tab -Function Complete

if ($env:TERM_PROGRAM -eq "vscode") {
    Set-PSReadLineKeyHandler -Chord 'Ctrl+w' -Function BackwardKillWord
}

$GitPromptSettings.DefaultPromptPrefix.Text = '$(Get-Date -f "MM-dd HH:mm:ss") '
$GitPromptSettings.DefaultPromptPrefix.ForegroundColor = [ConsoleColor]::Magenta
$GitPromptSettings.DefaultPromptAbbreviateHomeDirectory = $true

function Run-PreCommit { pre-commit run -a }
Set-Alias -Name pc -Value Run-PreCommit
function Run-LazyGit { lazygit }
Set-Alias -Name lg -Value Run-LazyGit
function Activate-Venv { venv/scripts/activate }
Set-Alias -Name v -Value Activate-Venv

Invoke-Expression (& { (zoxide init powershell | Out-String) })
